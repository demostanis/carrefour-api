post_install() {
  echo "The Carrefour API server has been installed."
  echo "By default, the session is stored in /var/lib/carrefour-api/carrefour_session.json."
  echo "If you need to update your session, log in to carrefour.fr in the MCP container and ask your agent."
  echo "To start the server, run: systemctl enable --now carrefour-api.service"
}

post_upgrade() {
  post_install
}
